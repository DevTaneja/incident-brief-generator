# Test Service Configuration
TEST_SERVICE_HOST="0.0.0.0"
TEST_SERVICE_PORT=8001

# Error Simulation
ERROR_RATE=0.2              # 20% of requests will fail
SLOW_REQUEST_RATE=0.1       # 10% of requests will be slow

# Splunk Configuration (where to send logs)
SPLUNK_HEC_URL="https://localhost:8088/services/collector"
SPLUNK_HEC_TOKEN="your_splunk_token_here"

# New Relic Configuration (where to send metrics)
NEW_RELIC_LICENSE_KEY="your_license_key_here"
NEW_RELIC_APP_NAME="test-service"

# Logging
LOG_LEVEL="INFO"

NEW_RELIC_LICENSE_KEY = "your_liscense_key"
